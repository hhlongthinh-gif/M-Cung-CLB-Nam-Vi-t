<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đại Chiến Kẹo Ngọt - Standalone</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap');
        
        body {
            font-family: 'Inter', 'Roboto', sans-serif;
            margin: 0;
            padding: 0;
            overflow: hidden;
            background-color: #3b82f6;
        }

        .notion-grid {
            background-image: radial-gradient(#e5e7eb 1px, transparent 1px);
            background-size: 20px 20px;
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 8px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(0,0,0,0.05);
            border-radius: 10px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(0,0,0,0.1);
            border-radius: 10px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(0,0,0,0.2);
        }

        @keyframes bounce-slow {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        .animate-bounce-slow {
            animation: bounce-slow 3s infinite ease-in-out;
        }

        @keyframes happy-shake {
            0%, 100% { transform: rotate(0deg) scale(1); }
            25% { transform: rotate(5deg) scale(1.1); }
            75% { transform: rotate(-5deg) scale(1.1); }
        }
        .animate-happy-shake {
            animation: happy-shake 0.5s infinite ease-in-out;
        }

        /* 3D Dice Styles */
        .dice-container {
            perspective: 1000px;
            width: 100px;
            height: 100px;
        }
        .dice {
            width: 100%;
            height: 100%;
            position: relative;
            transform-style: preserve-3d;
            transition: transform 1s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .dice-face {
            position: absolute;
            width: 100px;
            height: 100px;
            background: white;
            border: 4px solid #4338ca;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
            font-weight: bold;
            color: #4338ca;
            box-shadow: inset 0 0 20px rgba(0,0,0,0.1);
        }
        .front  { transform: rotateY(0deg) translateZ(50px); }
        .back   { transform: rotateY(180deg) translateZ(50px); }
        .right  { transform: rotateY(90deg) translateZ(50px); }
        .left   { transform: rotateY(-90deg) translateZ(50px); }
        .top    { transform: rotateX(90deg) translateZ(50px); }
        .bottom { transform: rotateX(-90deg) translateZ(50px); }

        @keyframes dice-rolling {
            0% { transform: rotateX(0deg) rotateY(0deg) rotateZ(0deg); }
            100% { transform: rotateX(720deg) rotateY(1080deg) rotateZ(360deg); }
        }
        .dice-rolling {
            animation: dice-rolling 1s infinite linear;
        }

        @keyframes slide-in-left {
            from { transform: translateX(-50px) scale(0.95); opacity: 0; }
            to { transform: translateX(0) scale(1); opacity: 1; }
        }
        .animate-slide-in-left {
            animation: slide-in-left 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }

        @keyframes slide-in-right {
            from { transform: translateX(50px) scale(0.95); opacity: 0; }
            to { transform: translateX(0) scale(1); opacity: 1; }
        }
        .animate-slide-in-right {
            animation: slide-in-right 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }

        @keyframes explosion {
            0% { transform: scale(0); opacity: 0; }
            50% { transform: scale(2); opacity: 1; }
            100% { transform: scale(3); opacity: 0; }
        }
        .animate-explosion {
            animation: explosion 0.6s ease-out forwards;
        }

        @keyframes shake {
            0%, 100% { transform: translate(0, 0); }
            10%, 30%, 50%, 70%, 90% { transform: translate(-4px, -4px); }
            20%, 40%, 60%, 80% { transform: translate(4px, 4px); }
        }
        .animate-shake {
            animation: shake 0.5s ease-in-out;
        }

        @keyframes hit {
            0% { transform: translate(-50%, -50%) scale(1); }
            50% { transform: translate(-50%, -50%) scale(1.4) rotate(15deg); filter: brightness(1.5); }
            100% { transform: translate(-50%, -50%) scale(1); }
        }
        .animate-hit {
            animation: hit 0.4s ease-out;
        }

        @keyframes fade-in {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .animate-fade-in {
            animation: fade-in 0.3s ease-out forwards;
        }

        @keyframes slide-in-top {
            from { transform: translateY(-100%); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        .animate-slide-in-top {
            animation: slide-in-top 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }

        @keyframes slide-in-up {
            from { transform: translateY(20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        .animate-slide-in-up {
            animation: slide-in-up 0.4s ease-out forwards;
        }

        .board-tile {
            transition: all 0.3s ease;
        }
        .board-tile:hover {
            transform: scale(1.05);
            z-index: 10;
        }

        .player-token {
            transition: left 0.4s cubic-bezier(0.4, 0, 0.2, 1), top 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
    </style>
</head>
<body>
    <div id="app"></div>

    <script>
        // --- Constants ---
        const BOARD_W = 10;
        const BOARD_H = 10;
        const TOTAL_TILES = BOARD_W * BOARD_H;
        const MAX_PLAYER_HEALTH = 3;
        const MAX_ZOMBIE_HEALTH = 3;
        const TILE_SIZE = 80;

        const CHARACTERS = [
            { type: 'phoenix', name: 'Phượng Hoàng', emoji: '🐦', ability: 'Hồi sinh tại chỗ khi hết máu' },
            { type: 'mermaid', name: 'Tiên Cá', emoji: '🧜‍♀️', ability: 'Hồi 1 máu mỗi khi di chuyển' },
            { type: 'dragon', name: 'Hỏa Long', emoji: '🐉', ability: 'Gây 1 sát thương xung quanh khi dừng' },
            { type: 'mage', name: 'Pháp Sư', emoji: '🧙‍♀️', ability: 'Dịch chuyển đến ô bất kỳ trong tầm 1-6' },
            { type: 'warrior', name: 'Chiến Binh', emoji: '⚔️', ability: 'Gây 2 sát thương cho zombie khi va chạm' },
            { type: 'scout', name: 'Trinh Sát', emoji: '🏃‍♂️', ability: 'Di chuyển thêm 1 ô mỗi lượt' },
            { type: 'healer', name: 'Y Sĩ', emoji: '🏥', ability: 'Hồi máu cho đồng đội xung quanh' },
            { type: 'ninja', name: 'Ninja', emoji: '🥷', ability: 'Tàng hình, không bị zombie tấn công' }
        ];

        // --- State ---
        let state = {
            gameState: 'start', // start, mode_selection, player_count, selection, playing, victory
            gameMode: 'advanced_dice',
            playerCount: 2,
            players: [],
            turnIndex: 0,
            zombies: [],
            selectedCharacters: [],
            selectionSlot: 0,
            diceValue: 1,
            isRolling: false,
            isMoving: false,
            victoryInfo: null,
            activeEffect: null,
            skillTargeting: null,
            isAimingBomb: false,
            explosionPos: null,
            isShaking: false,
            bombIndices: [],
            zombieSpawnIndices: [],
            cloverIndices: [],
            trapIndices: [],
            hasSeenTrapExplanation: false,
            boardSpaces: []
        };

        // --- Logic ---
        function generateBoard() {
            const spaces = [];
            for (let i = 0; i < TOTAL_TILES; i++) {
                const row = Math.floor(i / BOARD_W);
                const col = i % BOARD_W;
                const isEvenRow = row % 2 === 0;
                const x = (isEvenRow ? col : (BOARD_W - 1 - col)) * TILE_SIZE;
                const y = (BOARD_H - 1 - row) * TILE_SIZE;
                spaces.push({ id: i, x, y });
            }
            state.boardSpaces = spaces;

            // Randomize special tiles
            const available = Array.from({ length: TOTAL_TILES - 2 }, (_, i) => i + 1);
            const shuffle = arr => arr.sort(() => Math.random() - 0.5);
            const shuffled = shuffle(available);

            state.bombIndices = shuffled.slice(0, 8);
            state.zombieSpawnIndices = shuffled.slice(8, 16);
            state.cloverIndices = shuffled.slice(16, 24);
            state.trapIndices = shuffled.slice(24, 32);
        }

        function initGame(characters = null) {
            generateBoard();
            const count = state.playerCount;
            const newPlayers = [];
            
            for (let i = 0; i < count; i++) {
                const team = i < Math.ceil(count / 2) ? 1 : 2;
                const char = characters ? characters[i] : CHARACTERS[i % CHARACTERS.length];
                newPlayers.push({
                    id: i,
                    team,
                    character: char,
                    pos: 0,
                    health: MAX_PLAYER_HEALTH,
                    maxHealth: MAX_PLAYER_HEALTH,
                    bombs: 2,
                    statusEffects: {}
                });
            }

            state.players = newPlayers;
            state.turnIndex = 0;
            state.zombies = [];
            state.gameState = 'playing';
            render();
        }

        async function rollDice() {
            if (state.isRolling || state.isMoving) return;
            state.isRolling = true;
            render();

            await new Promise(r => setTimeout(r, 1000));
            const val = Math.floor(Math.random() * 6) + 1;
            state.diceValue = val;
            state.isRolling = false;
            render();

            await new Promise(r => setTimeout(r, 500));
            handleMove(val);
        }

        async function handleMove(steps) {
            if (state.isMoving) return;
            const p = state.players[state.turnIndex];

            // Basic mode or special characters skip skill targeting
            if (steps === 1 && !state.gameMode.startsWith('basic') && !['phoenix', 'mermaid'].includes(p.character.type)) {
                state.skillTargeting = { steps, player: p };
                render();
                return;
            }

            await executeMove(p, steps);
        }

        async function executeMove(p, steps, targetId = null, isExtraMove = false) {
            state.isMoving = true;
            state.skillTargeting = null;
            render();

            let currentPos = p.pos;
            const direction = steps > 0 ? 1 : -1;
            const absSteps = Math.abs(steps);

            for (let i = 0; i < absSteps; i++) {
                currentPos += direction;
                if (currentPos < 0) currentPos = 0;
                if (currentPos >= TOTAL_TILES) currentPos = TOTAL_TILES - 1;

                state.players = state.players.map(pl => pl.id === p.id ? { ...pl, pos: currentPos } : pl);
                
                // Mermaid ability
                if (p.character.type === 'mermaid') {
                    state.players = state.players.map(pl => pl.id === p.id ? { ...pl, health: Math.min(pl.maxHealth, pl.health + 1) } : pl);
                }

                render();
                await new Promise(r => setTimeout(r, 300));

                // Check zombie collision
                const zombieAtPos = state.zombies.find(z => z.pos === currentPos);
                if (zombieAtPos) {
                    state.activeEffect = { type: 'combat' };
                    state.explosionPos = state.boardSpaces[currentPos];
                    state.isShaking = true;
                    render();
                    await new Promise(r => setTimeout(r, 600));
                    state.activeEffect = null;
                    state.explosionPos = null;
                    state.isShaking = false;

                    const damageToZombie = p.character.type === 'warrior' ? 2 : 1;
                    state.zombies = state.zombies.map(z => z.id === zombieAtPos.id ? { ...z, health: z.health - damageToZombie } : z).filter(z => z.health > 0);
                    state.players = state.players.map(pl => pl.id === p.id ? { ...pl, health: pl.health - 1, isHit: true } : pl);
                    render();
                    await new Promise(r => setTimeout(r, 400));
                    state.players = state.players.map(pl => pl.id === p.id ? { ...pl, isHit: false } : pl);
                    
                    const updatedP = state.players.find(pl => pl.id === p.id);
                    if (updatedP.health <= 0) {
                        if (p.character.type === 'phoenix') {
                            state.players = state.players.map(pl => pl.id === p.id ? { ...pl, health: MAX_PLAYER_HEALTH } : pl);
                        } else {
                            state.players = state.players.map(pl => pl.id === p.id ? { ...pl, health: MAX_PLAYER_HEALTH, pos: 0 } : pl);
                            currentPos = 0;
                        }
                    }
                    render();
                }

                if (currentPos === TOTAL_TILES - 1) break;
            }

            // Skill application
            if (steps === 1 && !state.gameMode.startsWith('basic')) {
                await applySkill(p, targetId);
            }

            // Tile effects
            const finalPos = currentPos;
            if (state.cloverIndices.includes(finalPos)) {
                state.players = state.players.map(pl => pl.id === p.id ? { ...pl, health: Math.min(pl.maxHealth, pl.health + 1) } : pl);
            } else if (state.trapIndices.includes(finalPos)) {
                state.activeEffect = { type: 'trap', message: !state.hasSeenTrapExplanation ? 'CHÚ Ý: Đây là BẪY! Bạn sẽ bị văng lùi lại ngẫu nhiên từ 3-10 ô.' : null };
                state.explosionPos = state.boardSpaces[finalPos];
                state.isShaking = true;
                state.hasSeenTrapExplanation = true;
                render();
                await new Promise(r => setTimeout(r, state.activeEffect.message ? 4000 : 1000));
                state.activeEffect = null;
                state.explosionPos = null;
                state.isShaking = false;

                const backSteps = Math.floor(Math.random() * 8) + 3;
                state.players = state.players.map(pl => pl.id === p.id ? { ...pl, isHit: true, statusEffects: { ...pl.statusEffects, statusMessage: `BÙM! Văng lùi ${backSteps} ô` } } : pl);
                render();
                await new Promise(r => setTimeout(r, 500));
                state.players = state.players.map(pl => pl.id === p.id ? { ...pl, isHit: false } : pl);
                state.isMoving = false; // Reset for recursive call
                await executeMove(p, -backSteps, null, true);
                return;
            } else if (state.zombieSpawnIndices.includes(finalPos)) {
                const spawnPos = Math.max(0, finalPos - 6);
                state.zombies.push({ id: Date.now(), pos: spawnPos, health: MAX_ZOMBIE_HEALTH });
            } else if (state.bombIndices.includes(finalPos)) {
                state.players = state.players.map(pl => pl.id === p.id ? { ...pl, bombs: pl.bombs + 1 } : pl);
            }

            // Victory check
            if (finalPos === TOTAL_TILES - 1) {
                state.victoryInfo = { winnerTeam: p.team, winnerPlayer: p };
                state.gameState = 'victory';
                confetti({ particleCount: 150, spread: 70, origin: { y: 0.6 } });
            } else if (!isExtraMove) {
                const nextTurn = (state.turnIndex + 1) % state.players.length;
                state.turnIndex = nextTurn;
                if (nextTurn === 0) moveZombies();
            }

            state.isMoving = false;
            render();
        }

        async function applySkill(p, targetId) {
            if (p.character.type === 'dragon') {
                const targets = state.players.filter(pl => pl.team !== p.team && Math.abs(pl.pos - p.pos) <= 2);
                state.players = state.players.map(pl => targets.some(t => t.id === pl.id) ? { ...pl, health: Math.max(0, pl.health - 1) } : pl);
            } else if (p.character.type === 'healer') {
                const allies = state.players.filter(pl => pl.team === p.team && pl.id !== p.id && Math.abs(pl.pos - p.pos) <= 3);
                state.players = state.players.map(pl => allies.some(a => a.id === pl.id) ? { ...pl, health: Math.min(pl.maxHealth, pl.health + 1) } : pl);
            } else if (p.character.type === 'scout') {
                await executeMove(p, 1, null, true);
            }
            render();
        }

        function moveZombies() {
            state.zombies = state.zombies.map(z => {
                const nextPos = z.pos + 1;
                return { ...z, pos: nextPos };
            }).filter(z => z.pos < TOTAL_TILES);
            
            // Check if zombie hit any player
            state.zombies.forEach(z => {
                const hitPlayer = state.players.find(p => p.pos === z.pos);
                if (hitPlayer && hitPlayer.character.type !== 'ninja') {
                    state.players = state.players.map(p => p.id === hitPlayer.id ? { ...p, health: p.health - 1, pos: Math.max(0, p.pos - 2) } : p);
                }
            });
            render();
        }

        // --- UI Components ---
        function render() {
            const app = document.getElementById('app');
            app.innerHTML = '';

            if (state.gameState === 'start') {
                app.innerHTML = `
                    <div class="h-screen w-screen flex flex-col items-center justify-center bg-blue-500 overflow-hidden">
                        <div class="relative z-10 flex flex-col items-center">
                            <h1 class="text-[10vw] md:text-[12vw] font-black mb-12 tracking-tighter text-white drop-shadow-2xl text-center leading-[0.9] uppercase">
                                ĐẠI CHIẾN<br/>KẸO NGỌT
                            </h1>
                            <button onclick="state.gameState = 'mode_selection'; render();" class="px-20 py-8 bg-yellow-400 border-8 border-white text-white rounded-3xl font-black text-5xl hover:scale-110 active:scale-95 transition-all shadow-[0_20px_0_#b45309] hover:translate-y-[5px] active:translate-y-[20px] active:shadow-none uppercase tracking-widest flex items-center gap-4">
                                CHƠI NGAY! 🚀
                            </button>
                        </div>
                    </div>
                `;
            } else if (state.gameState === 'mode_selection') {
                const modes = [
                    { id: 'basic_dice', label: 'Cơ bản - có xí ngầu', icon: '🎲', desc: 'Không chọn chiến binh, dùng xí ngầu máy tính' },
                    { id: 'basic_manual', label: 'Cơ bản - không xí ngầu', icon: '🔢', desc: 'Không chọn chiến binh, tự chọn số bước' },
                    { id: 'advanced_dice', label: 'Nâng cao - có xí ngầu', icon: '🧙‍♀️🎲', desc: 'Có chọn chiến binh, dùng xí ngầu máy tính' },
                    { id: 'advanced_manual', label: 'Nâng cao - không xí ngầu', icon: '🧙‍♀️🔢', desc: 'Có chọn chiến binh, tự chọn số bước' },
                ];
                app.innerHTML = `
                    <div class="h-screen w-screen flex flex-col items-center justify-center bg-indigo-600 p-8 overflow-hidden">
                        <div class="max-w-6xl w-full z-10 bg-white p-12 rounded-[40px] border-8 border-white shadow-2xl flex flex-col items-center">
                            <h2 class="text-5xl font-black text-indigo-600 mb-12 uppercase tracking-widest text-center">CHỌN CHẾ ĐỘ CHƠI</h2>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full">
                                ${modes.map(m => `
                                    <button onclick="state.gameMode = '${m.id}'; state.gameState = 'player_count'; render();" class="group p-8 bg-indigo-50 border-4 border-indigo-100 rounded-3xl hover:border-indigo-500 hover:bg-white transition-all text-left flex items-center gap-6 shadow-sm hover:shadow-xl hover:-translate-y-2">
                                        <div class="text-7xl group-hover:scale-110 transition-transform">${m.icon}</div>
                                        <div>
                                            <div class="text-2xl font-black text-indigo-700 uppercase mb-2">${m.label}</div>
                                            <div class="text-indigo-400 font-bold uppercase text-sm tracking-tight">${m.desc}</div>
                                        </div>
                                    </button>
                                `).join('')}
                            </div>
                            <button onclick="state.gameState = 'start'; render();" class="mt-12 text-indigo-300 font-black text-xl uppercase tracking-widest hover:text-indigo-500 transition-colors">Quay lại</button>
                        </div>
                    </div>
                `;
            } else if (state.gameState === 'player_count') {
                app.innerHTML = `
                    <div class="h-screen w-screen flex flex-col items-center justify-center bg-emerald-500 p-8 overflow-hidden">
                        <div class="max-w-2xl w-full z-10 bg-white p-12 rounded-[40px] border-8 border-white shadow-2xl flex flex-col items-center">
                            <h2 class="text-4xl font-black text-emerald-600 mb-12 uppercase tracking-widest text-center">SỐ NGƯỜI CHƠI</h2>
                            <div class="flex gap-6 mb-12">
                                ${[2, 3, 4, 5, 6].map(n => `
                                    <button onclick="state.playerCount = ${n}; render();" class="w-20 h-20 rounded-2xl border-4 font-black text-3xl transition-all ${state.playerCount === n ? 'bg-emerald-500 border-white text-white scale-110 shadow-lg' : 'bg-emerald-50 border-emerald-100 text-emerald-300 hover:border-emerald-300'}">
                                        ${n}
                                    </button>
                                `).join('')}
                            </div>
                            <button onclick="onPlayerCountContinue()" class="px-20 py-6 bg-emerald-500 border-8 border-white text-white rounded-2xl font-black text-4xl hover:scale-110 active:scale-95 transition-all shadow-lg uppercase tracking-widest">TIẾP TỤC! 🚀</button>
                            <button onclick="state.gameState = 'mode_selection'; render();" class="mt-8 text-emerald-300 font-black text-xl uppercase tracking-widest hover:text-emerald-500 transition-colors">Quay lại</button>
                        </div>
                    </div>
                `;
            } else if (state.gameState === 'selection') {
                const allSelected = state.selectedCharacters.every(c => c !== null);
                app.innerHTML = `
                    <div class="h-screen w-screen flex flex-col items-center justify-center bg-pink-500 p-4 md:p-8 overflow-hidden">
                        <div class="max-w-[95vw] w-full h-[90vh] z-10 bg-white p-6 md:p-10 rounded-3xl border-8 border-white shadow-2xl flex flex-col items-center relative overflow-y-auto custom-scrollbar">
                            <div class="flex justify-between items-center w-full mb-8">
                                <h2 class="text-3xl font-black text-pink-600 uppercase tracking-widest drop-shadow-sm">CHỌN CHIẾN BINH</h2>
                                <div class="px-6 py-2 rounded-full border-2 border-white text-lg font-black text-white shadow-sm ${state.selectionSlot < Math.ceil(state.playerCount / 2) ? 'bg-blue-500' : 'bg-pink-600'}">
                                    LƯỢT CHỌN: ${state.selectionSlot < Math.ceil(state.playerCount / 2) ? 'ĐỘI 1' : 'ĐỘI 2'}
                                </div>
                            </div>
                            <div class="flex flex-wrap justify-center w-full mb-12 gap-8">
                                ${state.selectedCharacters.map((char, i) => {
                                    const team = i < Math.ceil(state.playerCount / 2) ? 1 : 2;
                                    const isCurrent = state.selectionSlot === i;
                                    return `
                                        <button onclick="onCancelSelection(${i})" class="w-24 h-32 rounded-xl border-4 flex flex-col items-center justify-center text-5xl shadow-sm transition-all relative group ${isCurrent ? (team === 1 ? 'border-blue-400 bg-blue-50 scale-110' : 'border-pink-400 bg-pink-50 scale-110') : (team === 1 ? 'border-blue-100 bg-white hover:bg-red-50 hover:border-red-200' : 'border-pink-100 bg-white hover:bg-red-50 hover:border-red-200')}">
                                            ${char?.emoji || '?'}
                                            <div class="text-[10px] font-black absolute bottom-2 uppercase group-hover:hidden ${team === 1 ? 'text-blue-400' : 'text-pink-400'}">Đội ${team}</div>
                                            ${char ? '<div class="hidden group-hover:block text-[10px] font-black text-red-500 absolute bottom-2 uppercase">HỦY</div>' : ''}
                                        </button>
                                    `;
                                }).join('')}
                            </div>
                            <div class="grid grid-cols-4 md:grid-cols-8 gap-4 w-full mb-8">
                                ${CHARACTERS.map((char, idx) => {
                                    const isSelected = state.selectedCharacters.some(sc => sc?.type === char.type);
                                    return `
                                        <button ${isSelected || allSelected ? 'disabled' : ''} onclick="onSelectCharacter('${char.type}')" 
                                                class="flex flex-col items-center p-4 rounded-xl border-4 transition-all group relative h-64 animate-slide-in-up ${isSelected ? 'bg-gray-100 border-gray-200 opacity-50 grayscale cursor-not-allowed' : 'bg-blue-50 border-blue-200 hover:border-blue-500 hover:scale-105'}"
                                                style="animation-delay: ${idx * 0.05}s">
                                            <div class="text-6xl mb-4 group-hover:scale-110 transition-transform">${char.emoji}</div>
                                            <div class="text-lg font-black text-blue-700 uppercase tracking-tighter mb-2 text-center leading-none">${char.name}</div>
                                            <div class="text-[9px] text-blue-900 font-bold text-center leading-tight uppercase tracking-tight">${char.ability}</div>
                                            ${isSelected ? '<div class="absolute inset-0 flex items-center justify-center"><span class="bg-white text-pink-600 font-black px-2 py-1 rounded-full text-[10px] border-2 border-pink-600 uppercase tracking-widest shadow-sm transform -rotate-12">ĐÃ CHỌN</span></div>' : ''}
                                        </button>
                                    `;
                                }).join('')}
                            </div>
                            ${allSelected ? `<button onclick="initGame(state.selectedCharacters)" class="px-24 py-6 bg-green-500 border-8 border-white text-white rounded-2xl font-black text-4xl hover:scale-110 active:scale-95 transition-all shadow-lg uppercase tracking-widest animate-pulse">LAUNCH 🚀</button>` : ''}
                        </div>
                    </div>
                `;
            } else if (state.gameState === 'playing') {
                const currentPlayer = state.players[state.turnIndex];
                const appScale = 0.8;

                app.innerHTML = `
                    <div class="h-screen w-screen flex transition-all duration-700 bg-blue-500 overflow-hidden">
                        <!-- Left Panel -->
                        <div class="w-80 h-full bg-white border-r-4 border-white p-4 flex flex-col z-50 shadow-md overflow-y-auto custom-scrollbar">
                            <div class="text-3xl font-black text-blue-600 uppercase mb-6 flex items-center gap-3">🔵 ĐỘI 1</div>
                            ${currentPlayer && currentPlayer.team === 1 ? renderHeroCard(currentPlayer) : ''}
                            <div class="flex flex-col gap-4 flex-1">
                                ${state.players.filter(p => p.team === 1).map(p => renderPlayerCard(p)).join('')}
                            </div>
                        </div>

                        <!-- Middle Panel -->
                        <div class="flex-1 relative overflow-hidden flex items-center justify-center bg-white notion-grid">
                            <!-- Turn Indicator -->
                            <div class="absolute top-4 left-1/2 -translate-x-1/2 z-[80] pointer-events-none">
                                <div class="bg-white/90 backdrop-blur-md px-8 py-3 rounded-full border-4 ${currentPlayer.team === 1 ? 'border-blue-500 text-blue-600' : 'border-pink-500 text-pink-600'} shadow-2xl animate-slide-in-top">
                                    <div class="text-xl font-black uppercase tracking-widest flex items-center gap-3">
                                        <span class="text-2xl">${currentPlayer.character.emoji}</span>
                                        LƯỢT CỦA ${currentPlayer.character.name.toUpperCase()}
                                    </div>
                                </div>
                            </div>

                            ${state.skillTargeting ? `
                                <div class="absolute inset-0 z-[100] bg-black/40 flex items-center justify-center animate-fade-in">
                                    <div class="bg-white p-8 rounded-2xl border-4 border-blue-500 shadow-2xl max-w-xl w-full text-center">
                                        <h3 class="text-3xl font-black text-blue-700 uppercase tracking-tighter mb-4">CHỌN MỤC TIÊU KỸ NĂNG</h3>
                                        <p class="text-gray-500 font-bold mb-6 uppercase text-sm">${state.skillTargeting.player.character.name} đang sử dụng kỹ năng!</p>
                                        <div class="grid grid-cols-2 gap-4 max-h-[60vh] overflow-y-auto p-2">
                                            ${state.players.filter(p => p.id !== state.skillTargeting.player.id).map(p => `
                                                <button onclick="executeMove(state.players[${state.skillTargeting.player.id}], ${state.skillTargeting.steps}, ${p.id})" class="p-4 bg-blue-50 border-4 border-blue-100 rounded-xl hover:border-blue-500 transition-all flex items-center gap-4">
                                                    <div class="text-4xl">${p.character.emoji}</div>
                                                    <div class="text-left">
                                                        <div class="font-black text-blue-700 uppercase">${p.character.name}</div>
                                                        <div class="text-[10px] font-bold text-blue-400 uppercase">Đội ${p.team}</div>
                                                    </div>
                                                </button>
                                            `).join('')}
                                        </div>
                                        <button onclick="state.skillTargeting = null; render();" class="mt-8 text-gray-400 font-black uppercase tracking-widest hover:text-gray-600">Hủy bỏ</button>
                                    </div>
                                </div>
                            ` : ''}

                            ${state.isAimingBomb ? `
                                <div class="absolute inset-0 z-[100] bg-black/40 flex items-center justify-center animate-fade-in">
                                    <div class="bg-white p-8 rounded-2xl border-4 border-red-500 shadow-2xl max-w-xl w-full text-center">
                                        <h3 class="text-3xl font-black text-red-700 uppercase tracking-tighter mb-4">CHỌN MỤC TIÊU NÉM BOM 💣</h3>
                                        <div class="grid grid-cols-2 gap-4 max-h-[60vh] overflow-y-auto p-2">
                                            ${state.players.filter(p => p.team !== currentPlayer.team).map(p => `
                                                <button onclick="onUseBomb(${p.id})" class="p-4 bg-red-50 border-4 border-red-100 rounded-xl hover:border-red-500 transition-all flex items-center gap-4">
                                                    <div class="text-4xl">${p.character.emoji}</div>
                                                    <div class="text-left">
                                                        <div class="font-black text-red-700 uppercase">${p.character.name}</div>
                                                        <div class="text-[10px] font-bold text-red-400 uppercase">Đội ${p.team}</div>
                                                    </div>
                                                </button>
                                            `).join('')}
                                        </div>
                                        <button onclick="state.isAimingBomb = false; render();" class="mt-8 text-gray-400 font-black uppercase tracking-widest hover:text-gray-600">Hủy bỏ</button>
                                    </div>
                                </div>
                            ` : ''}

                            ${state.activeEffect ? `
                                <div class="absolute inset-0 z-[100] pointer-events-none flex items-center justify-center">
                                    ${state.activeEffect.type === 'trap' ? `
                                        <div class="flex flex-col items-center">
                                            <div class="text-9xl animate-bounce">💥</div>
                                            ${state.activeEffect.message ? `<div class="mt-8 bg-black/80 text-white p-8 rounded-3xl border-4 border-orange-500 max-w-md text-center shadow-2xl"><div class="text-3xl font-black text-orange-500 mb-4 uppercase">CẢNH BÁO BẪY!</div><div class="text-xl font-bold">${state.activeEffect.message}</div></div>` : ''}
                                        </div>
                                    ` : `
                                        <div class="flex flex-col items-center">
                                            <div class="relative"><div class="text-9xl animate-ping absolute inset-0 opacity-50">⚔️</div><div class="text-9xl animate-bounce relative z-10">🧟👊💥</div></div>
                                            <div class="mt-8 bg-red-600 text-white px-10 py-4 rounded-full font-black text-4xl uppercase border-4 border-white shadow-2xl animate-pulse">CHIẾN ĐẤU!!!</div>
                                        </div>
                                    `}
                                </div>
                            ` : ''}

                            <div class="relative origin-center ${state.isShaking ? 'animate-shake' : ''}" style="transform: scale(${appScale}); width: ${(BOARD_W-1)*TILE_SIZE + TILE_SIZE}px; height: ${(BOARD_H-1)*TILE_SIZE + TILE_SIZE}px">
                                <div class="relative w-full h-full">
                                    <!-- Board Tiles -->
                                    <div class="absolute inset-0 z-0">
                                        ${state.boardSpaces.map(s => renderTile(s)).join('')}
                                    </div>
                                    <!-- Zombies -->
                                    ${state.zombies.map(z => renderZombie(z)).join('')}
                                    <!-- Players -->
                                    ${state.players.map(p => renderPlayerToken(p)).join('')}
                                    
                                    <!-- Explosion Effect -->
                                    ${state.explosionPos ? `
                                        <div class="absolute z-[60] pointer-events-none text-7xl animate-explosion" style="left: ${state.explosionPos.x + TILE_SIZE/2}px; top: ${state.explosionPos.y + TILE_SIZE/2}px; transform: translate(-50%, -50%)">
                                            💥
                                        </div>
                                    ` : ''}
                                </div>
                            </div>

                            <!-- Dice UI -->
                            ${state.gameMode.endsWith('dice') && !state.isMoving && !state.skillTargeting ? `
                                <div class="absolute inset-0 flex items-center justify-center z-[70] pointer-events-none">
                                    <button onclick="rollDice()" ${state.isRolling ? 'disabled' : ''} class="pointer-events-auto group relative flex flex-col items-center justify-center transition-all duration-300">
                                        <div class="dice-container">
                                            <div class="dice ${state.isRolling ? 'dice-rolling' : ''}" style="transform: ${!state.isRolling ? getDiceRotation(state.diceValue) : ''}">
                                                <div class="dice-face front">⚀</div>
                                                <div class="dice-face back">⚅</div>
                                                <div class="dice-face right">⚂</div>
                                                <div class="dice-face left">⚃</div>
                                                <div class="dice-face top">⚁</div>
                                                <div class="dice-face bottom">⚄</div>
                                            </div>
                                        </div>
                                        <div class="mt-24 bg-indigo-600 text-white px-10 py-4 rounded-full font-black text-3xl uppercase border-4 border-white shadow-[0_10px_0_#4338ca]">
                                            ${state.isRolling ? 'Đang thảy...' : `Thảy: ${state.diceValue}`}
                                        </div>
                                    </button>
                                </div>
                            ` : ''}
                        </div>

                        <!-- Right Panel -->
                        <div class="w-80 h-full bg-white border-l-4 border-white p-4 flex flex-col z-50 shadow-md overflow-y-auto custom-scrollbar">
                            <div class="text-3xl font-black text-pink-600 uppercase mb-6 flex items-center gap-3 justify-end">ĐỘI 2 🔴</div>
                            ${currentPlayer && currentPlayer.team === 2 ? renderHeroCard(currentPlayer) : ''}
                            <div class="flex flex-col gap-4 flex-1">
                                ${state.players.filter(p => p.team === 2).map(p => renderPlayerCard(p)).join('')}
                            </div>
                        </div>
                    </div>
                `;
            } else if (state.gameState === 'victory') {
                app.innerHTML = `
                    <div class="fixed inset-0 z-[100] flex items-center justify-center bg-black/40 p-4">
                        <div class="bg-white p-20 rounded-3xl shadow-2xl flex flex-col items-center text-center max-w-4xl w-full border-[12px] border-yellow-400 relative">
                            <div class="text-[160px] mb-8">🏆</div>
                            <h2 class="text-8xl font-black mb-6 text-blue-600 uppercase">CHIẾN THẮNG!</h2>
                            <div class="text-4xl font-black text-pink-600 mb-10 uppercase tracking-widest bg-pink-50 px-10 py-4 rounded-full border-4 border-pink-200">ĐỘI ${state.victoryInfo.winnerTeam} THẮNG CUỘC!</div>
                            <button onclick="location.reload()" class="px-16 py-6 bg-blue-600 text-white rounded-2xl font-black text-3xl hover:scale-110 active:scale-95 transition-all shadow-[0_10px_0_#1e3a8a] uppercase">CHƠI LẠI 🔄</button>
                        </div>
                    </div>
                `;
            }
        }

        function renderTile(s) {
            const isBomb = state.bombIndices.includes(s.id);
            const isZombieSpawn = state.zombieSpawnIndices.includes(s.id);
            const isClover = state.cloverIndices.includes(s.id);
            const isTrap = state.trapIndices.includes(s.id);
            const isStart = s.id === 0;
            const isEnd = s.id === TOTAL_TILES - 1;

            let content = '';
            let bgColor = 'bg-white';
            if (isStart) { content = '🏠'; bgColor = 'bg-green-100'; }
            else if (isEnd) { content = '🏁'; bgColor = 'bg-yellow-100'; }
            else if (isBomb) content = '💣';
            else if (isZombieSpawn) content = '🧟';
            else if (isClover) content = '🍀';
            else if (isTrap) content = '⚠️';
            else content = s.id + 1;

            return `
                <div class="absolute board-tile border-2 border-gray-100 flex items-center justify-center text-xl font-black text-gray-300 rounded-xl shadow-sm ${bgColor}" 
                     style="left: ${s.x}px; top: ${s.y}px; width: ${TILE_SIZE}px; height: ${TILE_SIZE}px">
                    ${content}
                </div>
            `;
        }

        function renderPlayerToken(p) {
            const space = state.boardSpaces[p.pos];
            if (!space) return '';
            const offset = (p.id % 4) * 10 - 15;
            return `
                <div class="absolute player-token z-30 pointer-events-none ${p.isHit ? 'animate-hit' : ''}" style="left: ${space.x + TILE_SIZE/2 + offset}px; top: ${space.y + TILE_SIZE/2 + offset}px; transform: translate(-50%, -50%)">
                    <div class="flex flex-col items-center">
                        <div class="text-5xl drop-shadow-lg animate-bounce-slow">${p.character.emoji}</div>
                        <div class="mt-1 px-2 py-0.5 rounded-full text-[10px] font-black text-white border-2 border-white shadow-sm ${p.team === 1 ? 'bg-blue-500' : 'bg-pink-500'}">
                            P${p.id + 1}
                        </div>
                    </div>
                </div>
            `;
        }

        function renderZombie(z) {
            const space = state.boardSpaces[z.pos];
            if (!space) return '';
            return `
                <div class="absolute z-20 pointer-events-none" style="left: ${space.x + TILE_SIZE/2}px; top: ${space.y + TILE_SIZE/2}px; transform: translate(-50%, -50%)">
                    <div class="flex flex-col items-center">
                        <div class="flex gap-0.5 mb-1 bg-white p-1 rounded-full px-2 border-2 border-red-500 shadow-lg">
                            ${Array.from({length: MAX_ZOMBIE_HEALTH}).map((_, i) => `
                                <div class="w-2 h-2 rounded-full ${i < z.health ? 'bg-red-500' : 'bg-gray-200'}"></div>
                            `).join('')}
                        </div>
                        <div class="text-5xl animate-pulse">🧟</div>
                    </div>
                </div>
            `;
        }

        function renderPlayerCard(p) {
            const isTurn = state.turnIndex === p.id;
            const isTeam1 = p.team === 1;
            const teamColor = isTeam1 ? 'blue' : 'pink';
            const bgColor = isTeam1 ? 'bg-blue-50' : 'bg-pink-50';
            const borderColor = isTeam1 ? 'border-blue-100' : 'border-pink-100';
            const textColor = isTeam1 ? 'text-blue-700' : 'text-pink-700';
            const subTextColor = isTeam1 ? 'text-blue-400' : 'text-pink-400';

            return `
                <div class="p-4 rounded-xl border-4 transition-all relative ${isTurn ? 'border-yellow-400 bg-white shadow-md z-10' : `${borderColor} ${bgColor} opacity-90 grayscale`}">
                    <div class="flex items-center gap-4 mb-3 ${isTeam1 ? '' : 'flex-row-reverse text-right'}">
                        <div class="w-16 h-16 rounded-xl ${isTeam1 ? 'bg-blue-100' : 'bg-pink-100'} flex items-center justify-center text-4xl border-2 border-white ${isTurn ? 'animate-bounce-slow' : ''}">${p.character.emoji}</div>
                        <div class="flex-1 min-w-0">
                            <div class="text-xl font-black ${textColor} truncate uppercase tracking-tighter">${p.character.name}</div>
                            <div class="text-xs font-black ${isTeam1 ? 'text-pink-500' : 'text-blue-500'} uppercase tracking-widest bg-white px-2 py-0.5 rounded-full inline-block mt-1">Ô số ${p.pos + 1}</div>
                        </div>
                    </div>
                    <div class="flex items-center gap-2 mb-3 ${isTeam1 ? '' : 'flex-row-reverse'}">
                        ${p.bombs > 0 ? `
                            <button 
                                onclick="if(${isTurn}) { state.isAimingBomb = true; render(); }"
                                class="flex items-center gap-1 px-3 py-1 rounded-full border-2 transition-all ${isTurn ? 'bg-red-500 border-white text-white hover:scale-110' : 'bg-gray-100 border-gray-200 text-gray-400 cursor-not-allowed'}"
                            >
                                <span class="text-lg">💣</span>
                                <span class="font-black text-sm">x${p.bombs}</span>
                            </button>
                        ` : ''}
                    </div>
                    <div class="flex items-center justify-between mb-2 ${isTeam1 ? '' : 'flex-row-reverse'}">
                        <div class="flex gap-2">
                            ${Array.from({length: p.maxHealth}).map((_, i) => `
                                <div class="w-6 h-3 rounded-full border-2 border-white ${i < p.health ? `bg-${teamColor}-500 shadow-md` : 'bg-gray-200'}"></div>
                            `).join('')}
                        </div>
                        ${isTurn ? `<span class="text-xs font-black text-${teamColor}-600 uppercase tracking-widest animate-pulse">Đang đi...</span>` : ''}
                    </div>
                    ${p.statusEffects.statusMessage ? `
                        <div class="mt-2 bg-gradient-to-r from-indigo-500 to-pink-500 p-0.5 rounded-2xl">
                            <div class="bg-white/90 rounded-[14px] p-2 text-[10px] font-black text-purple-700 uppercase tracking-widest flex items-center ${isTeam1 ? 'gap-2' : 'justify-end gap-2'}">
                                ${isTeam1 ? `✨ ${p.statusEffects.statusMessage}` : `${p.statusEffects.statusMessage} ✨`}
                            </div>
                        </div>
                    ` : ''}
                    ${isTurn && !state.isMoving && !state.skillTargeting && !state.gameMode.endsWith('dice') ? `
                        <div class="mt-4 pt-4 border-t-4 ${isTeam1 ? 'border-blue-100' : 'border-pink-100'}">
                            <div class="grid grid-cols-3 gap-2">
                                ${[1, 2, 3, 4, 5, 6].map(s => `
                                    <button onclick="handleMove(${s})" class="h-12 bg-${teamColor}-500 border-b-4 border-${teamColor}-700 text-white rounded-[15px] font-black text-xl hover:scale-105 active:translate-y-[4px] active:border-b-0 transition-all shadow-lg flex items-center justify-center border-2 border-white">${s}</button>
                                `).join('')}
                            </div>
                        </div>
                    ` : ''}
                </div>
            `;
        }

        function renderHeroCard(p) {
            const animationClass = p.team === 1 ? 'animate-slide-in-left' : 'animate-slide-in-right';
            return `
                <div class="mb-8 ${animationClass}">
                    <div class="p-6 rounded-[32px] border-[8px] shadow-xl w-full transition-all ${p.team === 1 ? 'bg-blue-600 border-white' : 'bg-pink-600 border-white'}">
                        <div class="flex flex-col items-center text-center">
                            <div class="w-32 h-32 bg-white/20 backdrop-blur-md rounded-[32px] flex items-center justify-center text-6xl mb-4 border-4 border-white/30 shadow-inner animate-bounce-slow">${p.character.emoji}</div>
                            <div class="text-3xl font-black text-white uppercase tracking-tighter mb-1 drop-shadow-lg">${p.character.name}</div>
                            <div class="text-[10px] font-black text-white/80 uppercase tracking-widest mb-4 bg-black/10 px-3 py-1 rounded-full">Đang đến lượt...</div>
                            <div class="w-full bg-white/10 backdrop-blur-sm p-4 rounded-2xl border-2 border-white/20">
                                <div class="text-[10px] font-black uppercase text-white/60 mb-1 tracking-widest">Kỹ năng đặc biệt</div>
                                <div class="text-sm font-bold text-white leading-tight uppercase tracking-tight">${p.character.ability}</div>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }

        function getDiceRotation(val) {
            const rotations = {
                1: 'rotateX(0deg) rotateY(0deg)',
                2: 'rotateX(-90deg) rotateY(0deg)',
                3: 'rotateX(0deg) rotateY(-90deg)',
                4: 'rotateX(0deg) rotateY(90deg)',
                5: 'rotateX(90deg) rotateY(0deg)',
                6: 'rotateX(180deg) rotateY(0deg)'
            };
            return rotations[val];
        }

        // --- Event Handlers ---
        window.initGame = initGame;
        window.rollDice = rollDice;
        window.handleMove = handleMove;
        window.executeMove = executeMove;

        window.onUseBomb = async (targetId) => {
            const p = state.players[state.turnIndex];
            if (p.bombs <= 0) return;

            const target = state.players.find(pl => pl.id === targetId);
            if (target) {
                state.explosionPos = state.boardSpaces[target.pos];
                state.isShaking = true;
            }

            state.players = state.players.map(pl => pl.id === p.id ? { ...pl, bombs: pl.bombs - 1 } : pl);
            state.isAimingBomb = false;
            render();

            await new Promise(r => setTimeout(r, 600));
            state.explosionPos = null;
            state.isShaking = false;
            
            state.players = state.players.map(pl => {
                if (pl.id === targetId) {
                    const newHealth = Math.max(0, pl.health - 2);
                    if (newHealth <= 0) {
                        return { ...pl, health: MAX_PLAYER_HEALTH, pos: 0 };
                    }
                    return { ...pl, health: newHealth };
                }
                return pl;
            });

            render();
        };

        window.onPlayerCountContinue = () => {
            if (state.gameMode.startsWith('basic')) {
                window.initGame();
            } else {
                state.selectedCharacters = Array(state.playerCount).fill(null);
                state.selectionSlot = 0;
                state.gameState = 'selection';
                render();
            }
        };

        window.onSelectCharacter = (type) => {
            const char = CHARACTERS.find(c => c.type === type);
            const next = [...state.selectedCharacters];
            next[state.selectionSlot] = char;
            state.selectedCharacters = next;
            
            const nextEmpty = next.findIndex(c => c === null);
            if (nextEmpty !== -1) state.selectionSlot = nextEmpty;
            render();
        };

        window.onCancelSelection = (idx) => {
            const next = [...state.selectedCharacters];
            next[idx] = null;
            state.selectedCharacters = next;
            state.selectionSlot = idx;
            render();
        };

        // Initialize
        render();
    </script>
</body>
</html>
